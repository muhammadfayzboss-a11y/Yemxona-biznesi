# .env.example — bu faylni nusxalab .env qiling va qiymatlarni to'ldiring
# .env fayli .gitignore tufayli git'ga kirmaydi (xavfsiz).

BOT_TOKEN=your_bot_token_from_botfather

# O'z Telegram ID'ingiz (@userinfobot orqali bilib oling).
# Bir nechta bo'lsa vergul bilan: 123456789, 987654321
ALLOWED_USER_IDS=123456789
