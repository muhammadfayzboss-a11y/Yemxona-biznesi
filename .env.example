# Telegram BotFather tokeni
BOT_TOKEN=1234567890:AAExampleTokenFromBotFather

# Admin Telegram ID lar, vergul bilan ajrating
ALLOWED_USER_IDS=123456789,987654321

# --- SMS (Eskiz.uz) ---
# Usuli 1: login orqali (birinchi ishga tushganda token oladi)
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your_eskiz_password
# Usuli 2: tayyor token (Eskiz cabinedan olingan) — ustuvor
# ESKIZ_TOKEN=your_eskiz_token

# SMS yuboruvchi nomi (Eskiz'da ro'yxatdan o'tkazilgan bo'lishi kerak)
ESKIZ_FROM=4546

# Do'kon telefon raqami (SMS oxirida ko'rsatiladi)
SHOP_PHONE=+998901234567

# Avtomatik eslatma (har kuni 19:00 da) - true/false
AUTO_REMINDER=false
